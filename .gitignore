```gitignore
# Build artifacts
*.dll
*.exe
*.pdb
*.so
*.dylib
*.o
*.obj
*.a
*.lib
*.out

# Dependencies
packages/
bin/
obj/
out/
dist/
build/
node_modules/
vendor/

# IDE files
.vs/
.vscode/
.idea/
*.userprefs
*.user
*.suo
*.csproj.user
*.userosscache
*.sln.docstates

# Temp files
*.tmp
*.temp
*.bak
*.cache

# Logs
*.log
logs/

# Environment
.env
.env.local
.env.*
!.env.example

# OS generated files
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
Icon?
```